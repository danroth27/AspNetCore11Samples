@page "/unions-demo"
@using BlazorWasmFeatures.Models
@using static BlazorWasmFeatures.Toast

<PageTitle>C# Unions in Blazor WebAssembly (trimming test)</PageTitle>

<h1>C# Unions in Blazor WebAssembly (.NET 11 Preview 6)</h1>

<p>
    Same Toast / SaveOutcome scenarios as the Server demo, running in a
    <strong>published, trimmed</strong> Blazor WebAssembly app. If unions needed
    runtime metadata that trimming removes, this page would fail.
</p>

<h2>Toast — <code>union ToastMessage(string, MarkupString, RenderFragment)</code></h2>

<Toast Message="@("Saved 3 items.")" Severity="ToastSeverity.Success" />
<Toast Message="@(new MarkupString("Saved <strong>3 items</strong>."))" Severity="ToastSeverity.Success" />
<Toast Message="@_rich" Severity="ToastSeverity.Warning" />

<h2>SaveOutcome — <code>union SaveOutcome(Saved, ValidationFailed, Conflict)</code></h2>

<button id="ok-btn"   class="btn btn-primary" @onclick="@(() => Apply(new Saved(7, DateTimeOffset.Now)))">Save (success)</button>
<button id="val-btn"  class="btn btn-warning" @onclick="@(() => Apply(new ValidationFailed(new[] { "Title required." })))">Save (validation)</button>
<button id="conf-btn" class="btn btn-danger"  @onclick="@(() => Apply(new Conflict("v7", "Reload to see latest.")))">Save (conflict)</button>

<p data-testid="status" class="mt-3"><strong>Last outcome:</strong> @_status</p>

@code {
    ToastMessage _rich;
    string _status = "(none)";

    protected override void OnInitialized()
    {
        _rich = new ToastMessage((RenderFragment)(b =>
            b.AddMarkupContent(0, "<em>RenderFragment toast — works in trimmed WASM</em>")));
    }

    void Apply(SaveOutcome outcome) => _status = outcome.Value switch
    {
        Saved s            => $"OK id={s.Id}",
        ValidationFailed v => $"VAL {string.Join("; ", v.Errors)}",
        Conflict c         => $"CONFLICT etag={c.CurrentETag}",
        _                  => "(unknown)",
    };
}
