@using BlazorWasmFeatures.Models

<div class="slot-host">
    @switch (Content.Value)
    {
        case string text:                          <span class="slot-text">@text</span>; break;
        case MarkupString markup:                  @markup;                              break;
        case RenderFragment fragment:              @fragment;                            break;
        default:                                   <em>(no content)</em>;                break;
    }
</div>

@code {
    [Parameter] public Slot Content { get; set; }
}
