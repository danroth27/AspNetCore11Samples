@page "/unions-demo"
@using BlazorFeatures.Models
@using static BlazorFeatures.Components.Toast
@rendermode InteractiveServer

<PageTitle>C# Unions in Blazor</PageTitle>

<h1>C# Unions in Blazor (.NET 11 Preview 6)</h1>

<p class="lead">
    Two scenarios every Blazor app hits, recast around a single C# language feature.
</p>

<hr />

<h2>Scenario 1 — The library-author's title/label parameter</h2>

<p>
    Every component library — MudBlazor, FluentUI, Radzen — ships a label, title, or
    toast message parameter as <em>two</em> parameters: a <code>string</code> for the
    80% case and a <code>RenderFragment</code> for the rest. That doubles the API,
    forces a precedence rule in the docs, and pushes a <code>null</code>-checking ladder
    into the component's render code.
</p>

<p>With C# unions, that parameter is one type:</p>

<pre><code class="language-csharp">public union ToastMessage(string, MarkupString, RenderFragment);

[Parameter, EditorRequired] public ToastMessage Message { get; set; }</code></pre>

<p>Three call shapes — same parameter, no precedence rules:</p>

@* Razor literal-attribute shortcut doesn't apply to non-string parameter types.
   Tracked at https://github.com/dotnet/razor/issues/13188 *@
<Toast Message="@("Saved 3 items.")" Severity="ToastSeverity.Success" />
<Toast Message="@(new MarkupString("Saved <strong>3 items</strong>, including <em>Widget #42</em>."))" Severity="ToastSeverity.Success" />
<Toast Message="@_richToast" Severity="ToastSeverity.Warning" />

<p>
    Inside the component, a <code>switch</code> on <code>Message.Value</code> handles
    every case. The compiler tells you if you forgot one — no <code>if</code> ladder,
    no <code>null</code> checks, no "which parameter wins."
</p>

<hr />

<h2>Scenario 2 — The outcome that never got handled</h2>

<p>
    A <code>Save</code> can succeed, can fail validation, or can hit an optimistic-concurrency
    conflict. Today components expose three <code>EventCallback</code>s and callers forget
    to wire <code>OnConflict</code>, so conflicts silently look like successes. With a union
    outcome, one callback delivers any of three shapes — and the consumer's
    <code>switch</code> is compiler-checked for exhaustiveness.
</p>

<pre><code class="language-csharp">public union SaveOutcome(Saved, ValidationFailed, Conflict);

[Parameter, EditorRequired]
public EventCallback&lt;SaveOutcome&gt; OnSaveCompleted { get; set; }</code></pre>

<SaveButton OnSaveCompleted="HandleOutcome" />

<div class="mt-3">
    <strong>Last outcome:</strong>
    @switch (_lastOutcome?.Value)
    {
        case Saved s:
            <span class="badge bg-success">Saved id=@s.Id at @s.At.ToString("T")</span>
            break;
        case ValidationFailed v:
            <span class="badge bg-warning text-dark">Validation failed</span>
            <ul class="mt-2">@foreach (var e in v.Errors) { <li>@e</li> }</ul>
            break;
        case Conflict c:
            <span class="badge bg-danger">Conflict — current ETag @c.CurrentETag</span>
            <div class="mt-2 text-muted">@c.Hint</div>
            break;
        case null:
            <span class="text-muted">(no save yet)</span>
            break;
    }
</div>

<hr />

<h2>Footnote — <code>DynamicComponent</code> and the boxing rule</h2>

<p>
    One thing to know if you build dynamic form/page renderers:
    <code>DynamicComponent.Parameters</code> is <code>IDictionary&lt;string, object&gt;</code>.
    The implicit conversion from a case type to the union runs at <em>compile</em> time,
    so dictionary values must be boxed as the union, not as the raw case value.
</p>

<ErrorBoundary @ref="_dynBoundary">
    <ChildContent>
        <DynamicComponent Type="typeof(Toast)" Parameters="_dynParams" />
    </ChildContent>
    <ErrorContent Context="ex">
        <div class="alert alert-danger">
            <strong>Runtime error:</strong> <code>@ex.Message</code>
        </div>
    </ErrorContent>
</ErrorBoundary>

<button class="btn btn-outline-secondary mt-2" @onclick="ToggleDynBoxing">
    @(_dynBoxedCorrectly ? "Try with wrong boxing (raw string)" : "Restore correct boxing")
</button>

@code {
    ToastMessage _richToast;
    SaveOutcome? _lastOutcome;

    Dictionary<string, object> _dynParams = new()
    {
        ["Message"]  = new ToastMessage("Boxed as ToastMessage — works."),
        ["Severity"] = ToastSeverity.Info,
    };
    bool _dynBoxedCorrectly = true;
    ErrorBoundary? _dynBoundary;

    protected override void OnInitialized()
    {
        _richToast = new ToastMessage((RenderFragment)(b =>
        {
            b.AddMarkupContent(0, "Saved 3 items. ");
            b.OpenElement(1, "button");
            b.AddAttribute(2, "class", "btn btn-sm btn-link p-0 align-baseline");
            b.AddAttribute(3, "onclick", EventCallback.Factory.Create(this, OnUndo));
            b.AddContent(4, "Undo");
            b.CloseElement();
        }));
    }

    void HandleOutcome(SaveOutcome outcome) => _lastOutcome = outcome;
    void OnUndo() => _lastOutcome = new Conflict("v7", "Undo invoked from the rich toast.");

    void ToggleDynBoxing()
    {
        _dynBoxedCorrectly = !_dynBoxedCorrectly;
        _dynBoundary?.Recover();
        _dynParams = new Dictionary<string, object>
        {
            ["Message"] = _dynBoxedCorrectly
                ? (object)new ToastMessage("Boxed as ToastMessage — works.")
                : (object)"Raw string — DynamicComponent can't assign this to a ToastMessage parameter.",
            ["Severity"] = ToastSeverity.Info,
        };
    }
}
